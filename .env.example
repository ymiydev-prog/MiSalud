# MiSalud Configuration
# Copy to .env and fill in your values

# Telegram Bot
MISALUD_TELEGRAM_TOKEN=your_bot_token_here
MISALUD_TELEGRAM_CHAT_ID=

# Database (default: SQLite in data/misalud.db)
MISALUD_DATABASE_URL=sqlite:///data/misalud.db

# Ollama (vision model)
OLLAMA_BASE_URL=http://localhost:11434

# Google OAuth (uses ~/.hermes/google_token.json by default)
